<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.config.DeptMapper">
  <!-- Select -->
  <select id="findByDeptno" resultType="DeptDTO" parameterType="int">
    select deptno, dname, loc from dept 
    where deptno = #{deptno}
  </select>
  <select id="findByDeptnoAndDname" resultType="DeptDTO" parameterType="DeptDTO">
    select deptno, dname, loc from dept 
    where deptno = #{deptno} and dname=#{dname}
  </select>
  <select id="findByDeptnoAndDnameMap" resultType="DeptDTO" parameterType="hashmap">
    select deptno, dname, loc from dept 
    where deptno = #{x} and dname=#{y}
  </select>
  <select id="findAll" resultType="com.dto.DeptDTO">
    select deptno, dname, loc from dept
  </select>
  <select id="findByDnameOrDeptno" resultType="DeptDTO" parameterType="DeptDTO">
    select deptno, dname, loc from dept
    where deptno=#{deptno} or dname=#{dname}
  </select>
  <select id="findByDeptnoLess" resultType="DeptDTO" parameterType="int">
    select * from dept
    where deptno &lt; #{deptno} <!-- deptno < int-->
  </select>
  <select id="findByDeptnoGreate" resultType="DeptDTO" parameterType="int">
    select * from dept
    where deptno &gt; #{deptno} <!-- deptno > int-->
  </select>
  <select id="findByDeptnoLessCDATA" resultType="DeptDTO" parameterType="int">
    <![CDATA[
    select * from dept
    where deptno < #{deptno}
    ]]>
  </select>
  <!-- Insert -->
  <insert id="insert" parameterType="DeptDTO">
  insert into dept (deptno, dname, loc)
  values (#{deptno}, #{dname}, #{loc})
  </insert>
  <!-- Update -->
  <update id="update" parameterType="hashmap">
  update dept
  set dname=#{dname}, loc=#{loc}
  where deptno=#{deptno}
  </update>
  <!-- Delete -->
  <delete id="delete" parameterType="int">
  delete from dept
  where deptno=#{deptno}
  </delete>
  
  <!-- emp join select -->
  <resultMap id="deptempJoinMap" type="DeptJoin">
    <id property="deptno" column="deptno"/>
    <result property="dname" column="dname" />
    <result property="loc" column="loc" />
    <!-- List<EmpDTO> empList 설정 -->
    <collection property="empList" ofType="EmpDTO">
    <!-- property는 DeptJoin 의 List 변수 이름
         ofType은 List가 저장할 데이터 타입 이름 -->
      <id property="empno" column="empno"/>
      <result property="ename" column="ename" />
      <result property="job" column="job" />
      <result property="mgr" column="mgr" />
      <result property="hiredate" column="hiredate" />
      <result property="sal" column="sal" />
      <result property="comm" column="comm" />
      <result property="deptno" column="deptno" />
    </collection>
  </resultMap>

  <select id="deptempJoin" resultMap="deptempJoinMap">
    select *
    from emp join dept on emp.deptno = dept.deptno
    order by empno desc
  </select>
  
</mapper>