<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE configuration
  PUBLIC "-//mybatis.org//DTD Config 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-config.dtd">
<configuration>
  <!--xml 주석-->
  <!-- jdbc.properties 등록-->
  <properties resource="com/config/jdbc.properties"></properties>
  <typeAliases>
  	<typeAlias alias="DeptDTO" type="com.dto.DeptDTO" />
  	<package name="com.dto" />
  </typeAliases>
  <environments default="development">
    <environment id="development">
      <transactionManager type="JDBC"/>
      <dataSource type="POOLED">
        <property name="driver" value="${jdbc.driver}"/>
        <!--value=com.mysql.cj.jdbc.Driver 이렇게 해도 된다.-->
        <!--대신, 키 값으로 외부 파일에 저장된 값을 불러올 수 있다.-->
        <!--그게 바로 ${key_name}이다-->
        <property name="url" value="${jdbc.url}"/>
        <property name="username" value="${jdbc.userid}"/>
        <property name="password" value="${jdbc.passwd}"/>
      </dataSource>
    </environment>
  </environments>
  <mappers>
    <mapper resource="com/config/DeptMapper.xml"/>
    <mapper resource="com/config/EmpMapper.xml"/>
  </mappers>
</configuration>